<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--
    殖民者制式改造 - 示例模板定义

    这里定义了几个预设的改造模板，玩家可以在游戏中通过"殖民者改造管理"窗口查看和使用。
    手术步骤按列表顺序依次执行，每个步骤对应一个RecipeDef的defName。

    你可以通过XML patch添加更多自定义模板，或修改现有模板的参数。
  -->

  <!-- ============================================
       模板1: 标准仿生改造
       为殖民者安装基础仿生部件，适用于游戏中期
  ============================================ -->
  <ColonistModificationTemplateDef>
    <defName>StandardBionicUpgrade</defName>
    <label>标准仿生改造</label>
    <description>为殖民者安装基础仿生部件，包括仿生臂、仿生腿和仿生眼。适用于游戏中期殖民地有足够资源之后。</description>

    <!-- 手术步骤列表（按顺序执行） -->
    <recipeDefNames>
      <li>InstallBionicArm</li>       <!-- 仿生臂 -->
      <li>InstallBionicLeg</li>       <!-- 仿生腿 -->
      <li>InstallBionicEye</li>       <!-- 仿生眼 -->
    </recipeDefNames>

    <!-- 失败自动重试 -->
    <autoRetryOnFailure>true</autoRetryOnFailure>

    <!-- 每个步骤最多重试3次 -->
    <maxRetriesPerStep>3</maxRetriesPerStep>

    <!-- 殖民地财富至少5000才触发 -->
    <minColonyWealth>5000</minColonyWealth>

    <!-- 只针对殖民者 -->
    <colonistsOnly>true</colonistsOnly>
    <includeSlaves>false</includeSlaves>

    <!-- 最小年龄 -->
    <minBiologicalAge>16</minBiologicalAge>

    <!-- 需要工业级药品 -->
    <minMedicineCategory>Industrial</minMedicineCategory>

    <!-- 需要玩家确认 -->
    <requirePlayerConfirmation>true</requirePlayerConfirmation>

    <!-- 延迟后3天再提示 -->
    <delayDays>3</delayDays>

    <!-- 优先级 -->
    <priority>10</priority>
  </ColonistModificationTemplateDef>

  <!-- ============================================
       模板2: 高级仿生改造
       包括高级仿生部件，适用于游戏后期
  ============================================ -->
  <ColonistModificationTemplateDef>
    <defName>AdvancedBionicUpgrade</defName>
    <label>高级仿生改造</label>
    <description>为殖民者安装高级仿生部件，极大提升工作效率和战斗能力。建议殖民地财富充足时执行。</description>

    <recipeDefNames>
      <li>InstallBionicSpine</li>     <!-- 仿生脊椎 -->
      <li>InstallBionicHeart</li>     <!-- 仿生心脏 -->
      <li>InstallBionicStomach</li>   <!-- 仿生胃 -->
      <li>InstallBionicArm</li>       <!-- 仿生臂 -->
      <li>InstallBionicLeg</li>       <!-- 仿生腿 -->
    </recipeDefNames>

    <autoRetryOnFailure>true</autoRetryOnFailure>
    <maxRetriesPerStep>5</maxRetriesPerStep>
    <minColonyWealth>50000</minColonyWealth>
    <colonistsOnly>true</colonistsOnly>
    <includeSlaves>false</includeSlaves>
    <minBiologicalAge>16</minBiologicalAge>
    <minMedicineCategory>Industrial</minMedicineCategory>
    <requirePlayerConfirmation>true</requirePlayerConfirmation>
    <delayDays>2</delayDays>
    <priority>20</priority>
  </ColonistModificationTemplateDef>

  <!-- ============================================
       模板3: 统一异种基因植入
       为殖民者植入统一的异种基因
       需要Biotech DLC
  ============================================ -->
  <ColonistModificationTemplateDef>
    <defName>StandardXenogermImplant</defName>
    <label>统一异种基因植入</label>
    <description>为所有符合条件的殖民者植入统一的异种基因。需要Biotech DLC和预先准备好的异种胚。</description>

    <recipeDefNames>
      <li>ImplantXenogerm</li>        <!-- 异种基因植入 -->
    </recipeDefNames>

    <autoRetryOnFailure>true</autoRetryOnFailure>
    <maxRetriesPerStep>3</maxRetriesPerStep>
    <minColonyWealth>10000</minColonyWealth>
    <colonistsOnly>true</colonistsOnly>
    <includeSlaves>true</includeSlaves>
    <minBiologicalAge>16</minBiologicalAge>
    <minMedicineCategory>Industrial</minMedicineCategory>
    <requirePlayerConfirmation>true</requirePlayerConfirmation>
    <delayDays>3</delayDays>
    <priority>15</priority>
  </ColonistModificationTemplateDef>

  <!-- ============================================
       模板4: 仿生器官快速安装（不需要玩家确认）
       适用于明确知道要改造哪些殖民者的场景
  ============================================ -->
  <ColonistModificationTemplateDef>
    <defName>QuickBionicInstall</defName>
    <label>快速仿生安装</label>
    <description>条件满足后自动为殖民者安装仿生臂，不需要玩家确认。适用于批量改造。</description>

    <recipeDefNames>
      <li>InstallBionicArm</li>
    </recipeDefNames>

    <autoRetryOnFailure>true</autoRetryOnFailure>
    <maxRetriesPerStep>5</maxRetriesPerStep>
    <minColonyWealth>0</minColonyWealth>
    <colonistsOnly>true</colonistsOnly>
    <requirePlayerConfirmation>false</requirePlayerConfirmation>
    <delayDays>1</delayDays>
    <priority>5</priority>
  </ColonistModificationTemplateDef>
</Defs>
